<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F2F5"
    android:fitsSystemWindows="true">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#1A1A2E"
            android:contentDescription="Back" />

        <!-- Bot avatar -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_bot_avatar">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_chat"
                app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ShopGiay AI"
                android:textColor="#1A1A2E"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_dot_green"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/tv_online_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang hoạt động"
                    android:textColor="#10B981"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_history_chat"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_icon_light"
            android:contentDescription="Lịch sử chat"
            android:padding="9dp"
            android:src="@drawable/ic_history"
            app:tint="#9CA3AF" />

        <ImageView
            android:id="@+id/btn_new_chat"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_btn_icon_light"
            android:contentDescription="Tạo chat mới"
            android:padding="9dp"
            android:src="@drawable/ic_add_chat"
            app:tint="#9CA3AF" />
    </LinearLayout>

    <!-- ===== MESSAGES ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- ===== TYPING INDICATOR ===== -->
    <LinearLayout
        android:id="@+id/layout_typing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <View android:id="@+id/dot1" android:layout_width="6dp" android:layout_height="6dp" android:background="@drawable/bg_dot_blue" android:layout_marginEnd="4dp" />
        <View android:id="@+id/dot2" android:layout_width="6dp" android:layout_height="6dp" android:background="@drawable/bg_dot_blue" android:layout_marginEnd="4dp" />
        <View android:id="@+id/dot3" android:layout_width="6dp" android:layout_height="6dp" android:background="@drawable/bg_dot_blue" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  AI đang trả lời..."
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- ===== QUICK SUGGESTIONS ===== -->
    <HorizontalScrollView
        android:id="@+id/scroll_suggestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/layout_suggestions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chip_1"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="Giày chạy bộ nào tốt?"
                android:textColor="#3B82F6"
                android:textSize="12sp"
                android:background="@drawable/bg_chip_suggestion"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_2"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="Có khuyến mãi gì?"
                android:textColor="#3B82F6"
                android:textSize="12sp"
                android:background="@drawable/bg_chip_suggestion"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_3"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="Size 42 có giày nào?"
                android:textColor="#3B82F6"
                android:textSize="12sp"
                android:background="@drawable/bg_chip_suggestion"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== INPUT BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:elevation="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="bottom">

        <EditText
            android:id="@+id/edt_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input_modern"
            android:hint="Nhắn tin cho AI..."
            android:textColorHint="#9CA3AF"
            android:inputType="textMultiLine"
            android:imeOptions="actionSend"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textSize="14sp"
            android:maxLines="4"
            android:layout_marginEnd="10dp" />

        <ImageView
            android:id="@+id/btn_send"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="11dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/bg_send_button"
            app:tint="@color/white"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
