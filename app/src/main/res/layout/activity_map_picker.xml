<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- OSMDroid Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/map_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_gradient_blue"
        android:fitsSystemWindows="true"
        android:paddingStart="4dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/btn_map_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Quay lại"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chọn địa điểm giao"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Center pin (fixed in center of screen) -->
    <ImageView
        android:id="@+id/iv_center_pin"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:layout_marginBottom="40dp"
        android:src="@drawable/ic_location"
        app:tint="#EF4444" />

    <!-- Bottom card: address + confirm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/white"
        android:elevation="16dp"
        android:padding="16dp">

        <!-- GPS button + label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/btn_my_location"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_my_location"
                android:background="@drawable/bg_logo_circle"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ đã chọn"
                    android:textColor="#9CA3AF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_picked_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kéo bản đồ để chọn vị trí..."
                    android:textColor="#1A1A2E"
                    android:textSize="13sp"
                    android:maxLines="2" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btn_confirm_location"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Xác nhận địa điểm này"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_gradient_blue"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</FrameLayout>
