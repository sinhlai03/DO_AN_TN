<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gradient_blue"
        android:gravity="center_vertical"
        android:paddingStart="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Quay lại"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm địa chỉ"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhãn địa chỉ"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edt_address_label"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="VD: Nhà, Công ty..."
                android:textSize="14sp"
                android:inputType="text"
                android:background="@drawable/bg_input_field"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Full address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ đầy đủ"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edt_address_full"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="Nhập địa chỉ đầy đủ..."
                android:textSize="14sp"
                android:inputType="textMultiLine"
                android:background="@drawable/bg_input_field"
                android:padding="12dp"
                android:gravity="top"
                android:layout_marginBottom="16dp" />

            <!-- GPS button -->
            <TextView
                android:id="@+id/btn_get_location"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Lấy vị trí hiện tại"
                android:textColor="@color/blue_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_chip_unselected"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="20dp" />

            <!-- Set primary checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cb_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt làm địa chỉ mặc định"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Save button -->
    <TextView
        android:id="@+id/btn_save_address"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Lưu địa chỉ"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_gradient_blue"
        android:clickable="true"
        android:focusable="true"
        android:layout_margin="16dp" />

</LinearLayout>
