<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header: back arrow + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_blue"
        android:gravity="bottom"
        android:fitsSystemWindows="true"
        android:paddingStart="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đơn của tôi"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Main content scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="6dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_my_orders_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_all"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:tag="all"
                        android:text="Tất cả" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_pending"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tag="pending"
                        android:text="Đã đặt" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_confirmed"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tag="confirmed"
                        android:text="Đã xác nhận" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_shipping"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tag="shipping"
                        android:text="Đang giao" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_done"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tag="done"
                        android:text="Hoàn thành" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_my_orders_cancelled"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:tag="cancelled"
                        android:text="Đã huỷ" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Orders list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_my_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Empty label -->
            <TextView
                android:id="@+id/tv_empty_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bạn chưa có đơn hàng nào"
                android:textColor="#9CA3AF"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

            <!-- Suggested products label -->
            <TextView
                android:id="@+id/tv_suggested_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Có thể bạn thích"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <!-- Suggested products grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_suggested_orders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
