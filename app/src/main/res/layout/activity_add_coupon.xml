<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_gradient_blue"
        android:gravity="center_vertical"
        android:paddingStart="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Quay lại"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm mã khuyến mãi"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Code -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã khuyến mãi"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edt_coupon_code"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="VD: GIAM10, SALE50..."
                android:textSize="14sp"
                android:inputType="textCapCharacters"
                android:background="@drawable/bg_input_field"
                android:padding="12dp"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <!-- Discount percent -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giảm giá (%)"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edt_discount"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="VD: 10 (giảm 10%)"
                android:textSize="14sp"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Min order -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đơn tối thiểu (đ)"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/edt_min_order"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="VD: 100000"
                android:textSize="14sp"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- Active switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cb_active"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kích hoạt mã này"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Save -->
    <TextView
        android:id="@+id/btn_save_coupon"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Lưu mã khuyến mãi"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_gradient_blue"
        android:clickable="true"
        android:focusable="true"
        android:layout_margin="16dp" />

</LinearLayout>
