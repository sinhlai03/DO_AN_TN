<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/blue_surface"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_gradient_blue"
        android:gravity="center_vertical"
        android:paddingStart="4dp">

        <ImageView
            android:id="@+id/btn_back_banner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Quay lại"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/tv_banner_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm banner"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Type selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại banner"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/rg_banner_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <RadioButton
                    android:id="@+id/rb_image"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Ảnh"
                    android:checked="true"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_video"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Video"
                    android:textSize="14sp" />
            </RadioGroup>

            <!-- Preview -->
            <FrameLayout
                android:id="@+id/img_banner_wrapper"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="@drawable/bg_input_field"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="6dp">

                <ImageView
                    android:id="@+id/img_banner_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Banner" />

                <TextView
                    android:id="@+id/tv_pick_banner_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Bấm để chọn ảnh"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_video_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/blue_primary"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiêu đề (không bắt buộc)"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edt_banner_title"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:hint="VD: Sale 50% hôm nay"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Save button -->
            <TextView
                android:id="@+id/btn_save_banner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Lưu banner"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/bg_gradient_blue"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
