<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFBFC">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:id="@+id/ll_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_gradient_blue"
                android:orientation="vertical"
                android:paddingTop="14dp"
                android:paddingBottom="0dp">

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_search_bar"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="Search"
                        android:src="@drawable/ic_nav_dashboard"
                        app:tint="#9CA3AF" />

                    <TextView
                        android:id="@+id/btn_open_search"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:gravity="center_vertical"
                        android:hint="Tìm kiếm giày..."
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- ===== BANNER SLIDER ===== -->
            <FrameLayout
                android:id="@+id/layout_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/banner_height"
                    android:background="@android:color/black" />

                <LinearLayout
                    android:id="@+id/ll_dots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp" />
            </FrameLayout>

            <!-- ===== COUPONS ===== -->
            <LinearLayout
                android:id="@+id/layout_coupons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingBottom="4dp">

                <!-- Header row: title + Xem tất cả -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ưu đãi cho bạn"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_see_all_coupon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xem tất cả ưu đãi →"
                        android:textColor="#3B82F6"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_coupons_home"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false" />
            </LinearLayout>


            <!-- ===== FLASH SALE ===== -->
            <LinearLayout
                android:id="@+id/layout_flash_sale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:visibility="gone">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="10dp">

                    <!-- Flash Sale badge with shimmer -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clipChildren="true">

                        <TextView
                            android:id="@+id/tv_flash_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡ Flash Sale"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/bg_flash_badge"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp" />

                        <View
                            android:id="@+id/flash_shimmer"
                            android:layout_width="40dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_shimmer_light"
                            android:rotation="20" />
                    </FrameLayout>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                    <!-- Countdown -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kết thúc"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tv_flash_hour"
                        android:layout_width="28dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_countdown"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="#1A1A2E"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" : "
                        android:textColor="#1A1A2E"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_flash_min"
                        android:layout_width="28dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_countdown"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="#1A1A2E"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" : "
                        android:textColor="#1A1A2E"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_flash_sec"
                        android:layout_width="28dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_countdown"
                        android:gravity="center"
                        android:text="00"
                        android:textColor="#1A1A2E"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_flash_sale"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <!-- ===== CATEGORIES ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Danh mục"
                    android:textColor="#1A1A2E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:paddingStart="16dp"
                    android:layout_marginBottom="10dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="12dp"
                    android:paddingEnd="8dp"
                    android:clipToPadding="false" />
            </LinearLayout>

            <!-- ===== PRODUCTS HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sản phẩm nổi bật"
                    android:textColor="#1A1A2E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem tất cả →"
                    android:textColor="@color/blue_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ===== PRODUCT GRID ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_home_products"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="80dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- FAB Chat AI -->
    <FrameLayout
        android:id="@+id/fab_chat_container"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:id="@+id/pulse1"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_send_button"
            android:alpha="0.3" />

        <View
            android:id="@+id/pulse2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_send_button"
            android:alpha="0.2" />

        <ImageView
            android:id="@+id/fab_chat"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:padding="15dp"
            android:src="@drawable/ic_chat"
            android:background="@drawable/bg_send_button"
            android:elevation="6dp"
            app:tint="@color/white" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
