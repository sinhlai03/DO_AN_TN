<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm địa chỉ"
        android:textColor="#1A1A2E"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Label -->
    <EditText
        android:id="@+id/edt_address_label"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Nhãn (VD: Nhà, Công ty...)"
        android:textSize="14sp"
        android:inputType="text"
        android:background="@drawable/bg_input_field"
        android:padding="12dp"
        android:layout_marginBottom="12dp" />

    <!-- Full address -->
    <EditText
        android:id="@+id/edt_address_full"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:hint="Địa chỉ đầy đủ"
        android:textSize="14sp"
        android:inputType="textMultiLine"
        android:background="@drawable/bg_input_field"
        android:padding="12dp"
        android:gravity="top"
        android:layout_marginBottom="12dp" />

    <!-- GPS button -->
    <TextView
        android:id="@+id/btn_get_location"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Lấy vị trí hiện tại"
        android:textColor="@color/blue_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_chip_unselected"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="16dp" />

    <!-- Set primary checkbox -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <CheckBox
            android:id="@+id/cb_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đặt làm địa chỉ mặc định"
            android:textColor="#1A1A2E"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Save button -->
    <TextView
        android:id="@+id/btn_save_address"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Lưu địa chỉ"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_gradient_blue"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
