<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header: back arrow + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_blue"
        android:gravity="bottom"
        android:fitsSystemWindows="true"
        android:paddingStart="4dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yêu thích"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Main content scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Favorites list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_favorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />

            <!-- Empty label -->
            <TextView
                android:id="@+id/tv_empty_favorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chưa có sản phẩm yêu thích nào"
                android:textColor="#9CA3AF"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone" />

            <!-- Suggested products label -->
            <TextView
                android:id="@+id/tv_suggested_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Có thể bạn thích"
                android:textColor="#1A1A2E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:visibility="gone" />

            <!-- Suggested products grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_suggested_favorites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
