<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp">

        <!-- Thumbnail container -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="80dp"
            android:layout_marginEnd="12dp">

            <!-- Image thumbnail -->
            <ImageView
                android:id="@+id/img_banner_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Banner"
                android:background="#F3F4F6" />

            <!-- Video preview -->
            <com.example.appbangiay.widget.FixedVideoView
                android:id="@+id/video_banner_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- Video play icon overlay -->
            <ImageView
                android:id="@+id/icon_video_play"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/bg_video_play_icon"
                android:padding="4dp"
                android:visibility="gone"
                app:tint="@color/white" />

            <!-- Video badge -->
            <TextView
                android:id="@+id/tv_video_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="4dp"
                android:text="▶ VIDEO"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold"
                android:background="@drawable/bg_video_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_banner_item_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Không có tiêu đề)"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_banner_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Actions -->
        <ImageView
            android:id="@+id/btn_edit_banner"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_nav_settings"
            android:padding="7dp"
            android:background="@drawable/bg_btn_icon_light"
            android:contentDescription="Edit"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="6dp"
            app:tint="#6B7280" />

        <ImageView
            android:id="@+id/btn_delete_banner"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@drawable/ic_delete"
            android:padding="7dp"
            android:background="@drawable/bg_btn_delete"
            android:contentDescription="Delete"
            android:clickable="true"
            android:focusable="true"
            app:tint="#EF4444" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
